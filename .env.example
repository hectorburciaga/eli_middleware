# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=production

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── Backend API ───────────────────────────────────────────────────────────────
# The task manager backend — on the same VM so we use localhost
BACKEND_URL=http://localhost:3001
BACKEND_PIN=your-admin-pin

# ── Auth ─────────────────────────────────────────────────────────────────────
# Shared secret between middleware and any channel (WhatsApp, email) that calls it
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MIDDLEWARE_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the middleware directly
# For now just the frontend and localhost
ALLOWED_ORIGINS=http://localhost:3000,http://FRONTEND_IP:3000

# ── User context ──────────────────────────────────────────────────────────────
# Used to personalize Claude's system prompt
USER_NAME=Hector
USER_INTERACTION_LANG=en
USER_OUTPUT_LANG=es
USER_TIMEZONE=America/Monterrey
USER_CONTEXT=Director of IAARQ (architecture firm) and BIMXcloud (AEC SaaS platform) in Monterrey, Mexico.
